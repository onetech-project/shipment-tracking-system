# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@postgres:5432/app

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_bytes_hex
JWT_REFRESH_SECRET=change_me_refresh_secret_64_bytes_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Account Security ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
SESSION_INACTIVITY_MINUTES=30

# ── Invitations ───────────────────────────────────────────
INVITATION_EXPIRY_HOURS=72

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shipment-tracking.local

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
BACKEND_PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000