# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@postgres:5432/app

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_bytes_hex
JWT_REFRESH_SECRET=change_me_refresh_secret_64_bytes_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Account Security ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
SESSION_INACTIVITY_MINUTES=30

# ── Invitations ───────────────────────────────────────────
INVITATION_EXPIRY_HOURS=72

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shipment-tracking.local

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
BACKEND_PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Shipment Import ───────────────────────────────────────
SHIPMENT_IMPORT_MAX_FILE_MB=10
SHIPMENT_IMPORT_CONCURRENCY=3
SHIPMENT_ID_REGEX=^[A-Z0-9-]{6,40}$

# Google Sheets integration
GOOGLE_CREDENTIALS_PATH=/absolute/path/to/config/serviceaccount.json
GOOGLE_SHEET_ID=google_sheet_id_here

# Sheet config file
SHEET_CONFIG_PATH=/absolute/path/to/config/sheets.json

# Sync interval (optional, defaults to 15000 ms)
SYNC_INTERVAL_MS=15000

# WebSocket CORS (set to your frontend origin)
WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# Enable Google Sheets integration (true/false)
GOOGLE_SHEETS_ENABLED=true