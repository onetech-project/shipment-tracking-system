# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@postgres:5432/app

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_bytes_hex
JWT_REFRESH_SECRET=change_me_refresh_secret_64_bytes_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Account Security ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
SESSION_INACTIVITY_MINUTES=30

# ── Invitations ───────────────────────────────────────────
INVITATION_EXPIRY_HOURS=72

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shipment-tracking.local

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
BACKEND_PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Shipment Import ───────────────────────────────────────
SHIPMENT_IMPORT_MAX_FILE_MB=10
SHIPMENT_IMPORT_CONCURRENCY=3
SHIPMENT_ID_REGEX=^[A-Z0-9-]{6,40}$

# ── Google Sheets Sync ────────────────────────────────────
# Absolute path to the Google Service Account JSON key file.
# Never commit the key file itself; only the path goes here.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json
# The Google Sheet ID (from the URL: /spreadsheets/d/<SHEET_ID>/)
SHEET_ID=
# The name of the sheet tab to read (default: Sheet1)
SHEET_TAB_NAME=Sheet1
# Target PostgreSQL table name (alphanumeric + underscore only)
SHEET_SYNC_TABLE=
# Column used as primary key for row matching between sheet and DB
SHEET_SYNC_PK_COLUMN=
# Poll interval in milliseconds (minimum 5000, default 15000)
SHEET_SYNC_INTERVAL_MS=15000
# Allowed CORS origin for the Socket.IO WebSocket gateway
FRONTEND_ORIGIN=http://localhost:3001